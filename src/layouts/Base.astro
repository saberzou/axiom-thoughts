---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="zh">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style is:global>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        font-size: 18px;
        -webkit-text-size-adjust: 100%;
      }

      body {
        background: #FFFFFF;
        color: #1A1A1A;
        font-family: 'Noto Sans SC', 'Google Sans', system-ui, -apple-system, sans-serif;
        font-weight: 300;
        line-height: 1.7;
        padding: 0 clamp(1rem, 5vw, 1.5rem);
      }

      :lang(en), .lang-en {
        font-family: 'Google Sans', system-ui, -apple-system, sans-serif;
      }
    </style>
    <style>
      .site-header {
        max-width: 56rem;
        margin: 0 auto;
        padding: 2rem 0 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .site-name {
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        text-decoration: none;
        color: #1A1A1A;
        font-family: 'Google Sans', system-ui, sans-serif;
      }

      .site-name:hover {
        color: #555;
      }

      .lang-toggle {
        display: flex;
        gap: 0.1rem;
        font-size: 0.75rem;
        font-family: 'Google Sans', system-ui, sans-serif;
      }

      .lang-btn {
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.2rem 0.5rem;
        color: #aaa;
        font-size: 0.75rem;
        font-family: inherit;
        border-radius: 4px;
        transition: color 0.15s;
      }

      .lang-btn.active {
        color: #1A1A1A;
        font-weight: 500;
      }

      .lang-btn:hover {
        color: #1A1A1A;
      }

      main {
        max-width: 56rem;
        margin: 0 auto;
      }

      footer {
        max-width: 56rem;
        margin: 4rem auto 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eee;
        font-size: 0.8rem;
        color: #aaa;
        font-family: 'Google Sans', system-ui, sans-serif;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <a href={import.meta.env.BASE_URL} class="site-name">Axiom Thoughts</a>
      <div class="lang-toggle">
        <button class="lang-btn active" data-lang="zh">中</button>
        <button class="lang-btn" data-lang="en">EN</button>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      Axiom Thoughts
    </footer>
    <script is:inline>
      function setLang(lang) {
        document.documentElement.setAttribute('data-lang', lang);
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.classList.toggle('active', btn.dataset.lang === lang);
        });
        document.querySelectorAll('[data-zh]').forEach(function(el) {
          el.textContent = lang === 'en' ? (el.dataset.en || el.dataset.zh) : el.dataset.zh;
        });
        localStorage.setItem('axiom-lang', lang);
      }

      document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.lang-btn').forEach(function(btn) {
          btn.addEventListener('click', function() {
            setLang(btn.dataset.lang);
          });
        });
        var saved = localStorage.getItem('axiom-lang');
        if (saved && saved !== 'zh') setLang(saved);
      });
    </script>
  </body>
</html>
