---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = await getCollection('thoughts');
const posts = allPosts
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const facets = [
  'Self',
  'Consciousness',
  'Reality',
  'Knowledge',
  'Language',
  'Civilization',
  'Power',
  'Ethics',
  'Human Mind',
  'Imagination',
];

const facetsZh: Record<string, string> = {
  'Self': '自我',
  'Consciousness': '意识',
  'Reality': '现实',
  'Knowledge': '知识',
  'Language': '语言',
  'Civilization': '文明',
  'Power': '权力',
  'Ethics': '伦理',
  'Human Mind': '心智',
  'Imagination': '想象力',
};

const facetColors: Record<string, string[]> = {
  'Self':          ['#f0ede8', '#d6cbb8', '#c4a97a', '#a8884e', '#8b6a2f', '#6b4f1a'],
  'Consciousness': ['#f0ede8', '#c8d5df', '#94b4cc', '#6393b4', '#3d7199', '#1f5278'],
  'Reality':       ['#f0ede8', '#cdd0c4', '#a6ac8e', '#7d8660', '#5c6640', '#3e4728'],
  'Knowledge':     ['#f0ede8', '#d3cac5', '#b09e94', '#8d7365', '#6e4f3e', '#4d3425'],
  'Language':      ['#f0ede8', '#d4c8bd', '#b89e8a', '#9a7760', '#7d5540', '#5e3a25'],
  'Civilization':  ['#f0ede8', '#cfc8c0', '#a99e96', '#837770', '#60524d', '#42322e'],
  'Power':         ['#f0ede8', '#c8c4d0', '#9e96b0', '#766c90', '#544870', '#3a2a52'],
  'Ethics':        ['#f0ede8', '#c6d2cc', '#93b2a4', '#63907c', '#3f7058', '#1f5038'],
  'Human Mind':    ['#f0ede8', '#bdd1e0', '#82afc8', '#4f8eb0', '#2d6f94', '#105175'],
  'Imagination':   ['#f0ede8', '#d5c4c8', '#b8909a', '#9a6070', '#7c384c', '#5e1a2e'],
};

const facetBarColor: Record<string, string> = {
  'Self': '#8b6a2f', 'Consciousness': '#3d7199', 'Reality': '#5c6640',
  'Knowledge': '#6e4f3e', 'Language': '#7d5540', 'Civilization': '#60524d',
  'Power': '#544870', 'Ethics': '#3f7058', 'Human Mind': '#2d6f94', 'Imagination': '#7c384c',
};
---
<Base title="Growth — Axiom Thoughts">
  <style>
    .growth-page {
      max-width: 64rem;
      margin: 0 auto;
    }

    .growth-title {
      font-size: 1.5rem;
      font-weight: 400;
      line-height: 1.35;
      margin-bottom: 1.5rem;
    }

    .growth-subtitle {
      font-size: 0.75rem;
      color: #999;
      margin-bottom: 2rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .mosaic-container {
      overflow-x: auto;
      padding-bottom: 1rem;
    }

    .mosaic {
      display: grid;
      gap: 3px;
      min-width: fit-content;
    }

    .facet-row {
      display: contents;
    }

    .facet-label {
      font-size: 0.7rem;
      color: #888;
      font-family: 'Google Sans', system-ui, sans-serif;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      padding-right: 0.75rem;
      white-space: nowrap;
      min-width: 6rem;
      position: sticky;
      left: 0;
      background: #FAF9F6;
      z-index: 5;
    }

    .cell {
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 3px;
      transition: transform 0.15s, box-shadow 0.15s;
      cursor: pointer;
      position: relative;
    }

    .cell:hover {
      transform: scale(1.15);
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
      z-index: 10;
    }

    .date-labels {
      display: contents;
    }

    .date-label {
      font-size: 0.55rem;
      color: #bbb;
      font-family: 'Google Sans', system-ui, sans-serif;
      text-align: center;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      height: 4rem;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding-top: 0.5rem;
    }

    .tooltip {
      display: none;
      position: fixed;
      background: rgba(30, 30, 30, 0.92);
      color: #f0ede8;
      padding: 0.5rem 0.75rem;
      border-radius: 6px;
      font-size: 0.72rem;
      line-height: 1.4;
      font-family: 'Google Sans', system-ui, sans-serif;
      pointer-events: none;
      z-index: 1000;
      max-width: 16rem;
      backdrop-filter: blur(8px);
    }

    .tooltip.show {
      display: block;
    }

    .legend {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 1.5rem;
      font-size: 0.65rem;
      color: #aaa;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .legend-cell {
      width: 1rem;
      height: 1rem;
      border-radius: 2px;
    }

    .back-link {
      display: inline-block;
      margin-top: 2.5rem;
      font-size: 0.8rem;
      color: #999;
      text-decoration: none;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .back-link:hover {
      color: #1A1A1A;
    }

    @media (max-width: 640px) {
      .mosaic-container {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }

    .facet-total {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding-left: 0.75rem;
      min-width: 6rem;
    }

    .total-bar-track {
      flex: 1;
      height: 2.2rem;
      max-height: 2.2rem;
      background: #f0ede8;
      border-radius: 3px;
      overflow: hidden;
    }

    .total-bar-fill {
      height: 100%;
      background: #8a7d5a;
      border-radius: 3px;
      transition: width 0.3s ease;
    }

    .total-number {
      font-size: 0.65rem;
      color: #999;
      font-family: 'Google Sans', system-ui, sans-serif;
      min-width: 1.2rem;
      text-align: right;
    }
  </style>

  <div class="growth-page">
    <h1 class="growth-title" data-zh="成长图谱" data-en="Growth Mosaic">成长图谱</h1>
    <p class="growth-subtitle" data-zh="每一格代表一篇阅读对某个维度的贡献" data-en="Each cell represents a reading's contribution to a facet">每一格代表一篇阅读对某个维度的贡献</p>

    <div class="mosaic-container">
      <div class="mosaic" style={`grid-template-columns: 6rem repeat(${posts.length}, 2.2rem) 6rem; grid-template-rows: repeat(${facets.length}, 2.2rem) 4rem;`}>
        {facets.map((facet, fi) => {
          const facetScores = posts.map(p => p.data.growth?.[facet] ?? 0);
          const total = facetScores.reduce((a: number, b: number) => a + b, 0);
          const max = posts.length * 5;
          const pct = Math.round((total / max) * 100);
          return (
          <Fragment>
            <div class="facet-label" data-zh={facetsZh[facet]} data-en={facet}>{facetsZh[facet]}</div>
            {posts.map((post, pi) => {
              const score = post.data.growth?.[facet] ?? 0;
              const colors = facetColors[facet] || ['#f0ede8','#d5cfc4','#bfb697','#a89e7c','#8a7d5a','#5c5233'];
              const bg = colors[Math.min(score, 5)];
              return (
                <div
                  class="cell"
                  style={`background: ${bg};`}
                  data-title={post.data.title}
                  data-title-en={post.data.title_en || post.data.title}
                  data-facet={facet}
                  data-facet-zh={facetsZh[facet]}
                  data-score={score}
                  data-date={post.data.date}
                />
              );
            })}
            <div class="facet-total">
              <div class="total-bar-track">
                <div class="total-bar-fill" style={`width: ${pct}%; background: ${facetBarColor[facet] || '#8a7d5a'};`}></div>
              </div>
              <span class="total-number">{total}</span>
            </div>
          </Fragment>
          );
        })}
        {/* Date labels at bottom */}
        <div class="facet-label"></div>
        {posts.map(post => (
          <div class="date-label">{post.data.date.slice(5)}</div>
        ))}
        <div></div>
      </div>
    </div>

    <div class="legend">
      <span>Low</span>
      <div class="legend-cell" style="background: #f0ede8;"></div>
      <div class="legend-cell" style="background: #c8d5df;"></div>
      <div class="legend-cell" style="background: #94b4cc;"></div>
      <div class="legend-cell" style="background: #6393b4;"></div>
      <div class="legend-cell" style="background: #3d7199;"></div>
      <div class="legend-cell" style="background: #1f5278;"></div>
      <span>High</span>
    </div>

    <a href={import.meta.env.BASE_URL} class="back-link">← All posts</a>
  </div>

  <div class="tooltip" id="tooltip"></div>

  <script is:inline>
    var tooltip = document.getElementById('tooltip');
    document.querySelectorAll('.cell').forEach(function(cell) {
      cell.addEventListener('mouseenter', function(e) {
        var lang = document.documentElement.getAttribute('data-lang') || 'zh';
        var title = lang === 'en' ? (cell.dataset.titleEn || cell.dataset.title) : cell.dataset.title;
        var facet = lang === 'en' ? cell.dataset.facet : cell.dataset.facetZh;
        var score = cell.dataset.score;
        var pips = '●'.repeat(Number(score)) + '○'.repeat(5 - Number(score));
        tooltip.innerHTML = '<div style="font-weight:500;margin-bottom:2px">' + title + '</div>' +
          '<div>' + facet + '  ' + pips + '</div>' +
          '<div style="color:#999;font-size:0.6rem;margin-top:2px">' + cell.dataset.date + '</div>';
        tooltip.classList.add('show');
      });
      cell.addEventListener('mousemove', function(e) {
        tooltip.style.left = (e.clientX + 12) + 'px';
        tooltip.style.top = (e.clientY - 10) + 'px';
      });
      cell.addEventListener('mouseleave', function() {
        tooltip.classList.remove('show');
      });
    });
  </script>
</Base>
