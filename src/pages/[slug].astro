---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('thoughts');
  const zhPosts = allPosts.filter(p => p.data.lang === 'zh');
  const enMap = new Map(
    allPosts
      .filter(p => p.data.lang === 'en')
      .map(p => [p.id.replace(/en$/, ''), p])
  );
  return zhPosts.map(post => ({
    params: { slug: post.id },
    props: { post, enPost: enMap.get(post.id) || null },
  }));
}

const { post, enPost } = Astro.props;
const { Content: ZhContent } = await render(post);
const enRendered = enPost ? await render(enPost) : null;
const EnContent = enRendered?.Content;

const AIC_IIIF = 'https://www.artic.edu/iiif/2';
const paintings = [
  { imageId: '3c27b499-af56-f0d5-93b5-a7f2f1ad5813', title: 'Water Lilies', artist: 'Claude Monet' },
  { imageId: 'a38e2828-ec6f-ece1-a30f-70243449197b', title: 'Stacks of Wheat (End of Summer)', artist: 'Claude Monet' },
  { imageId: '95be2572-b53d-8e7b-abc9-10eb48d4fa5d', title: 'The Beach at Sainte-Adresse', artist: 'Claude Monet' },
  { imageId: 'b0effb1c-ff23-bbaa-f809-9fd94e31c1a0', title: 'Cliff Walk at Pourville', artist: 'Claude Monet' },
  { imageId: '4d1b3ad0-14db-0d21-ad9f-17abb8bdfbb5', title: 'Bordighera', artist: 'Claude Monet' },
  { imageId: '4c364c64-2108-4e19-5fc5-1ab26ba924a7', title: 'Stacks of Wheat (End of Day, Autumn)', artist: 'Claude Monet' },
  { imageId: '8534685d-1102-e1e3-e194-94f6e925e8b0', title: 'Water Lily Pond', artist: 'Claude Monet' },
  { imageId: '838d8c33-a3b4-68ea-587b-87ceec2011af', title: 'Branch of the Seine near Giverny (Mist)', artist: 'Claude Monet' },
  { imageId: '03930df3-1e6c-eeca-8660-c0b22ca477ff', title: 'Houses of Parliament, London', artist: 'Claude Monet' },
  { imageId: 'e9179922-f68d-34c5-481d-abf49e046863', title: 'Charing Cross Bridge, London', artist: 'Claude Monet' },
  { imageId: '827d02ef-6765-9728-c07e-52ad22b73fd3', title: 'Waterloo Bridge, Sunlight Effect', artist: 'Claude Monet' },
  { imageId: '0f076222-52b2-9bb4-4409-72fdf485d895', title: 'A Turn in the Road', artist: 'Alfred Sisley' },
  { imageId: 'c4425cb6-d8b5-6390-603d-7f802406d05d', title: 'The Seine at Port-Marly', artist: 'Alfred Sisley' },
  { imageId: 'bcc9c3a7-f5b0-41af-210a-bd17797d77d9', title: 'The Loire', artist: 'Alfred Sisley' },
  { imageId: 'ed7aa098-e5c9-04dd-b09c-3416d1c56854', title: 'Watering Place at Marly', artist: 'Alfred Sisley' },
  { imageId: '674ba07f-9187-8954-29a1-c944272d86fa', title: 'A Corner of Moret-sur-Loing', artist: 'Alfred Sisley' },
  { imageId: '053f9be8-3617-c4ef-36cd-1deb5e13b288', title: 'Rabbit Warren at Pontoise, Snow', artist: 'Camille Pissarro' },
  { imageId: '3d950ecc-73f4-c28a-f216-0940b23fa5e8', title: 'The Banks of the Marne in Winter', artist: 'Camille Pissarro' },
  { imageId: 'b84a9755-ca8d-8bd5-5a59-e910b20e3ba5', title: 'Haymaking at Éragny', artist: 'Camille Pissarro' },
  { imageId: '4eb368b5-3b66-ae2c-bd4a-2643015e05fc', title: 'The Crystal Palace', artist: 'Camille Pissarro' },
  { imageId: 'd4e43d76-594b-ce65-c1a3-45c865624f70', title: 'Snow at Louveciennes', artist: 'Camille Pissarro' },
  { imageId: 'd4ca6321-8656-3d3f-a362-2ee297b2b813', title: 'The Bay of Marseille', artist: 'Paul Cézanne' },
  { imageId: '90bc0cec-0d4e-9af5-3912-52a082a428e5', title: 'Auvers, Panoramic View', artist: 'Paul Cézanne' },
  { imageId: 'd4bc1723-7cbc-d36d-a9cb-f84553f2a6f6', title: "The Poet's Garden", artist: 'Vincent van Gogh' },
  { imageId: '5512cee9-6d00-d01b-b0be-ac7843cc8f76', title: 'Fishing in Spring, Pont de Clichy', artist: 'Vincent van Gogh' },
  { imageId: '6cb22407-be79-bf0a-1a63-fdf2b99e035b', title: 'Terrace at the Moulin de la Galette', artist: 'Vincent van Gogh' },
  { imageId: 'caf4fa39-e2e8-344a-542c-2d9a03ec9d4b', title: 'Seascape', artist: 'Pierre-Auguste Renoir' },
  { imageId: '26e1c560-acca-3148-46dc-c144ac22bd3e', title: 'Near the Lake', artist: 'Pierre-Auguste Renoir' },
  { imageId: '5dfcbae3-6682-d1e6-0d1c-9eb8b5fd4a5e', title: 'Grove of Trees', artist: 'Pierre-Auguste Renoir' },
];

// Fallback: pick from pool excluding already-used painting_ids
const allPostsSlug = await getCollection('thoughts');
const usedIds = new Set(
  allPostsSlug.filter(p => p.data.painting_id).map(p => p.data.painting_id)
);
function getFallbackPainting(slug: string) {
  const available = paintings.filter(p => !usedIds.has(p.imageId));
  if (available.length === 0) return paintings[0];
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  return available[Math.abs(h) % available.length];
}

const fb = post.data.painting_id ? null : getFallbackPainting(post.id);
const paintingId = post.data.painting_id || fb!.imageId;
const paintingTitle = post.data.painting_title || fb?.title || '';
const paintingArtist = post.data.painting_artist || fb?.artist || '';
const imgUrl = `${AIC_IIIF}/${paintingId}/full/800,/0/default.jpg`;
---
<Base title={`${post.data.title} — Axiom Thoughts`}>
  <style>
    .post-wrapper {
      max-width: 38rem;
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: 1.5rem;
    }

    .post-date {
      font-size: 0.75rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.75rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 400;
      line-height: 1.35;
      margin-bottom: 1.5rem;
    }

    .post-painting {
      width: 100%;
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 0.5rem;
      line-height: 0;
    }

    .post-painting img {
      width: 100%;
      height: auto;
      display: block;
    }

    .post-painting-credit {
      font-size: 0.7rem;
      color: #bbb;
      margin-bottom: 2rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-content :global(p) {
      margin-bottom: 1.3rem;
    }

    .post-content :global(h2) {
      font-size: 1.15rem;
      font-weight: 500;
      margin: 2rem 0 0.75rem;
    }

    .post-content :global(h3) {
      font-size: 1rem;
      font-weight: 500;
      margin: 1.5rem 0 0.5rem;
    }

    .post-content :global(blockquote) {
      border-left: 2px solid #ddd;
      padding-left: 1rem;
      color: #555;
      margin: 1.5rem 0;
      font-style: italic;
    }

    .post-content :global(blockquote p) {
      margin-bottom: 0.5rem;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.3rem;
    }

    .post-content :global(li) {
      margin-bottom: 0.3rem;
    }

    .post-content :global(hr) {
      border: none;
      border-top: 1px solid #eee;
      margin: 2rem 0;
    }

    .back-link {
      display: inline-block;
      margin-top: 3rem;
      font-size: 0.8rem;
      color: #999;
      text-decoration: none;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .back-link:hover {
      color: #1A1A1A;
    }
  </style>

  <div class="post-wrapper">
    <article>
      <header class="post-header">
        <div class="post-date">{post.data.date}</div>
        <h1 class="post-title"
          data-zh={post.data.title}
          data-en={post.data.title_en || post.data.title}>
          {post.data.title}
        </h1>
      </header>
      <div class="post-painting">
        <img src={imgUrl} alt={`${paintingTitle} — ${paintingArtist}`} loading="lazy" />
      </div>
      <div class="post-painting-credit">{paintingTitle} · {paintingArtist}</div>
      <div class="post-content">
        <div class="content-zh">
          <ZhContent />
        </div>
        {EnContent && (
          <div class="content-en" style="display:none">
            <EnContent />
          </div>
        )}
      </div>
    </article>
    <a href={import.meta.env.BASE_URL} class="back-link">← All posts</a>
  </div>
</Base>
