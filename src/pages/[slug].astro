---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { paintings, AIC_IIIF } from '../data/paintings';

export async function getStaticPaths() {
  const allPosts = await getCollection('thoughts');
  const zhPosts = allPosts.filter(p => p.data.lang === 'zh');
  const enMap = new Map(
    allPosts
      .filter(p => p.data.lang === 'en')
      .map(p => [p.id.replace(/en$/, ''), p])
  );
  return zhPosts.map(post => ({
    params: { slug: post.id },
    props: { post, enPost: enMap.get(post.id) || null },
  }));
}

const { post, enPost } = Astro.props;
const { Content: ZhContent } = await render(post);
const enRendered = enPost ? await render(enPost) : null;
const EnContent = enRendered?.Content;

// Fallback: pick from pool excluding already-used painting_ids
const allPostsSlug = await getCollection('thoughts');
const usedIds = new Set(
  allPostsSlug.filter(p => p.data.painting_id).map(p => p.data.painting_id)
);
function getFallbackPainting(slug: string) {
  const available = paintings.filter(p => !usedIds.has(p.imageId));
  if (available.length === 0) return paintings[0];
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  return available[Math.abs(h) % available.length];
}

const fb = post.data.painting_id ? null : getFallbackPainting(post.id);
const paintingId = post.data.painting_id || fb!.imageId;
const paintingTitle = post.data.painting_title || fb?.title || '';
const paintingArtist = post.data.painting_artist || fb?.artist || '';
const imgUrl = `${AIC_IIIF}/${paintingId}/full/800,/0/default.jpg`;
---
<Base title={`${post.data.title} — Axiom Thoughts`}>
  <style>
    .post-wrapper {
      max-width: 38rem;
      margin: 0 auto;
    }

    .post-header {
      margin-bottom: 1.5rem;
    }

    .post-date {
      font-size: 0.75rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.75rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 400;
      line-height: 1.35;
      margin-bottom: 1.5rem;
    }

    .post-painting {
      width: 100%;
      border-radius: 4px;
      overflow: hidden;
      margin-bottom: 0.5rem;
      line-height: 0;
    }

    .post-painting img {
      width: 100%;
      height: auto;
      display: block;
    }

    .post-painting-credit {
      font-size: 0.7rem;
      color: #bbb;
      margin-bottom: 2rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-content :global(p) {
      margin-bottom: 1.3rem;
    }

    .post-content :global(h2) {
      font-size: 1.15rem;
      font-weight: 500;
      margin: 2rem 0 0.75rem;
    }

    .post-content :global(h3) {
      font-size: 1rem;
      font-weight: 500;
      margin: 1.5rem 0 0.5rem;
    }

    .post-content :global(blockquote) {
      border-left: 2px solid #ddd;
      padding-left: 1rem;
      color: #555;
      margin: 1.5rem 0;
      font-style: italic;
    }

    .post-content :global(blockquote p) {
      margin-bottom: 0.5rem;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.3rem;
    }

    .post-content :global(li) {
      margin-bottom: 0.3rem;
    }

    .post-content :global(hr) {
      border: none;
      border-top: 1px solid #eee;
      margin: 2rem 0;
    }

    .back-link {
      display: inline-block;
      margin-top: 3rem;
      font-size: 0.8rem;
      color: #999;
      text-decoration: none;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .back-link:hover {
      color: #1A1A1A;
    }
  </style>

  <div class="post-wrapper">
    <article>
      <header class="post-header">
        <div class="post-date">{post.data.date}</div>
        <h1 class="post-title"
          data-zh={post.data.title}
          data-en={post.data.title_en || post.data.title}>
          {post.data.title}
        </h1>
      </header>
      <div class="post-painting">
        <img src={imgUrl} alt={`${paintingTitle} — ${paintingArtist}`} loading="lazy" />
      </div>
      <div class="post-painting-credit">{paintingTitle} · {paintingArtist}</div>
      <div class="post-content">
        <div class="content-zh">
          <ZhContent />
        </div>
        {EnContent && (
          <div class="content-en" style="display:none">
            <EnContent />
          </div>
        )}
      </div>
    </article>
    <a href={import.meta.env.BASE_URL} class="back-link">← All posts</a>
  </div>
</Base>
