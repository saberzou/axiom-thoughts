---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('thoughts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const defaultIcon = 'Content-Files-Books-2--Streamline-Pixel';
---
<Base title={`${post.data.title} — Axiom Thoughts`}>
  <style>
    .post-header {
      margin-bottom: 2.5rem;
      max-width: 38rem;
    }

    .post-header-icon {
      width: 32px;
      height: 32px;
      margin-bottom: 1rem;
      image-rendering: pixelated;
    }

    .post-date {
      font-size: 0.75rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.5rem;
    }

    .post-title {
      font-size: 1.5rem;
      font-weight: 300;
      line-height: 1.35;
    }

    .post-content {
      max-width: 38rem;
    }

    .post-content :global(p) {
      margin-bottom: 1.3rem;
    }

    .post-content :global(h2) {
      font-size: 1.15rem;
      font-weight: 500;
      margin: 2rem 0 0.75rem;
    }

    .post-content :global(h3) {
      font-size: 1rem;
      font-weight: 500;
      margin: 1.5rem 0 0.5rem;
    }

    .post-content :global(blockquote) {
      border-left: 2px solid #ddd;
      padding-left: 1rem;
      color: #555;
      margin: 1.5rem 0;
      font-style: italic;
    }

    .post-content :global(blockquote p) {
      margin-bottom: 0.5rem;
    }

    .post-content :global(ul),
    .post-content :global(ol) {
      padding-left: 1.5rem;
      margin-bottom: 1.3rem;
    }

    .post-content :global(li) {
      margin-bottom: 0.3rem;
    }

    .post-content :global(hr) {
      border: none;
      border-top: 1px solid #eee;
      margin: 2rem 0;
    }

    .back-link {
      display: inline-block;
      margin-top: 3rem;
      font-size: 0.8rem;
      color: #999;
      text-decoration: none;
    }

    .back-link:hover {
      color: #111;
    }
  </style>

  <article>
    <header class="post-header">
      <img class="post-header-icon" src={`${import.meta.env.BASE_URL}/icons/${post.data.icon || defaultIcon}.svg`} alt="" />
      <div class="post-date">{post.data.date}</div>
      <h1 class="post-title">{post.data.title}</h1>
    </header>
    <div class="post-content">
      <Content />
    </div>
  </article>

  <a href={import.meta.env.BASE_URL} class="back-link">← All posts</a>
</Base>
