---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 100) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 100) {
        clean = clean.slice(0, 100) + '…';
      }
      return clean;
    }
  }
  return '';
}

// Impressionist landscape paintings from Art Institute of Chicago (open access)
const AIC_IIIF = 'https://www.artic.edu/iiif/2';
const paintings = [
  { imageId: '3c27b499-af56-f0d5-93b5-a7f2f1ad5813', title: 'Water Lilies', artist: 'Claude Monet' },
  { imageId: 'a38e2828-ec6f-ece1-a30f-70243449197b', title: 'Stacks of Wheat (End of Summer)', artist: 'Claude Monet' },
  { imageId: '95be2572-b53d-8e7b-abc9-10eb48d4fa5d', title: 'The Beach at Sainte-Adresse', artist: 'Claude Monet' },
  { imageId: '0f1cc0e0-e42e-be16-3f71-2022da38cb93', title: 'Arrival of the Normandy Train', artist: 'Claude Monet' },
  { imageId: '8534685d-1102-e1e3-e194-94f6e925e8b0', title: 'Water Lily Pond', artist: 'Claude Monet' },
  { imageId: 'f8fd76e9-c396-5678-36ed-6a348c904d27', title: 'Paris Street; Rainy Day', artist: 'Gustave Caillebotte' },
  { imageId: '2d484387-2509-5e8e-2c43-22f9981972eb', title: 'A Sunday on La Grande Jatte', artist: 'Georges Seurat' },
  { imageId: 'd4ca6321-8656-3d3f-a362-2ee297b2b813', title: 'The Bay of Marseille', artist: 'Paul Cézanne' },
  { imageId: '3a608f55-d76e-fa96-d0b1-0789fbc48f1e', title: 'Two Sisters (On the Terrace)', artist: 'Pierre-Auguste Renoir' },
  { imageId: '47c5bcb8-62ef-e5d7-55e7-f5121f409a30', title: 'Self-Portrait', artist: 'Vincent van Gogh' },
];

function slugHash(slug: string): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) {
    h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  }
  return Math.abs(h);
}

function getPainting(slug: string) {
  return paintings[slugHash(slug) % paintings.length];
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      opacity: 0.85;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 16 / 6;
      border-radius: 12px;
      overflow: hidden;
      background: #f0ede8;
      transition: opacity 0.2s;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {posts.map(post => {
      const painting = getPainting(post.id);
      const imgUrl = `${AIC_IIIF}/${painting.imageId}/full/400,/0/default.jpg`;
      return (
        <li class="post-card">
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
            <div class="post-thumb">
              <img src={imgUrl} alt={`${painting.title} — ${painting.artist}`} loading="lazy" />
            </div>
            <div class="post-card-body">
              <div class="post-card-date">{post.data.date}</div>
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-excerpt">{getExcerpt(post.body)}</p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>
