  { imageId: 'db94c894-a24c-c2e0-9db9-0506567a0152', title: 'Poppy Field (Giverny)', artist: 'Claude Monet' },
  { imageId: '2765aee9-3d78-ec6c-5c66-a1d9dc8173f6', title: "Rocks at Port-Goulphar, Belle-Île", artist: 'Claude Monet' },
  { imageId: '6f61a6fc-dcd8-e801-0ad8-5f7e561d91b6', title: 'Waterloo Bridge, Gray Weather', artist: 'Claude Monet' },
  { imageId: '1f925e43-ff81-5ad7-da75-b28ea651c09f', title: 'Irises', artist: 'Claude Monet' },
