---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 120) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 120) {
        clean = clean.slice(0, 120) + '…';
      }
      return clean;
    }
  }
  return '';
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-list {
      list-style: none;
    }

    .post-item {
      padding: 1.5rem 0;
    }

    .post-item + .post-item {
      border-top: 1px solid #f0f0f0;
    }

    .post-meta {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 0.75rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.3rem;
    }

    .post-title {
      font-size: 1.1rem;
      font-weight: normal;
      margin-bottom: 0.35rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .post-title a {
      color: #111;
      text-decoration: none;
    }

    .post-title a:hover {
      text-decoration: underline;
    }

    .post-icon {
      flex-shrink: 0;
      width: 16px;
      height: 16px;
      opacity: 0.45;
    }

    .post-excerpt {
      font-size: 0.9rem;
      color: #666;
      line-height: 1.6;
    }
  </style>

  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        <div class="post-meta">{post.data.date}</div>
        <h2 class="post-title">
          <svg class="post-icon" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 2h6v12H2a1 1 0 0 1-1-1V2zm8 0h6v11a1 1 0 0 1-1 1H9V2zM3 5h2v1H3V5zm3 0h1v1H6V5zM3 7h3v1H3V7zm0 2h2v1H3V9zm8-4h2v1h-2V5zm-1 0h1v1h-1V5zm1 2h2v1h-2V7zm0 2h1v1h-1V9z" fill-rule="evenodd"/>
          </svg>
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>{post.data.title}</a>
        </h2>
        <p class="post-excerpt">{getExcerpt(post.body)}</p>
      </li>
    ))}
  </ul>
</Base>
