---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 120) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 120) {
        clean = clean.slice(0, 120) + '…';
      }
      return clean;
    }
  }
  return '';
}

const defaultIcon = 'Content-Files-Books-2--Streamline-Pixel';
---
<Base title="Axiom Thoughts">
  <style>
    .post-list {
      list-style: none;
    }

    .post-item {
      padding: 1rem 0;
      display: flex;
      gap: 0.75rem;
      align-items: center;
    }

    .post-item + .post-item {
      border-top: 1px solid #f0f0f0;
    }

    .post-icon {
      flex-shrink: 0;
      width: 20px;
      height: 20px;
    }

    .post-icon img {
      width: 100%;
      height: 100%;
      image-rendering: pixelated;
    }

    .post-title {
      font-size: 1rem;
      font-weight: 400;
    }

    .post-title a {
      color: #111;
      text-decoration: none;
    }

    .post-title a:hover {
      text-decoration: underline;
    }
  </style>

  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        <div class="post-icon">
          <img src={`${import.meta.env.BASE_URL}/icons/${post.data.icon || defaultIcon}.svg`} alt="" />
        </div>
        <h2 class="post-title">
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>{post.data.title}</a>
        </h2>
      </li>
    ))}
  </ul>
</Base>
