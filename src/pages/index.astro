  { imageId: '838d8c33-a3b4-68ea-587b-87ceec2011af', title: 'Branch of the Seine near Giverny (Mist)', artist: 'Claude Monet' },
  { imageId: '66f95ea3-a11a-1cf4-6599-d0a49bb25744', title: 'On the Bank of the Seine, Bennecourt', artist: 'Claude Monet' },
