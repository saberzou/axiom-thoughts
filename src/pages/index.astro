---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { paintings, AIC_IIIF } from '../data/paintings';

const allPosts = await getCollection('thoughts');

// Only show zh posts in the index
const zhPosts = allPosts
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Build a map of en posts by base slug (strip ".en" suffix)
const enMap = new Map(
  allPosts
    .filter(p => p.data.lang === 'en')
    .map(p => [p.id.replace(/en$/, ''), p])
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 100) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 100) {
        clean = clean.slice(0, 100) + '…';
      }
      return clean;
    }
  }
  return '';
}

// Impressionist landscape paintings from Art Institute of Chicago (open access)
// Collect painting_ids already claimed by frontmatter
const usedIds = new Set(
  allPosts.filter(p => p.data.painting_id).map(p => p.data.painting_id)
);

// Auto-assign unique paintings to posts without painting_id
function getFallbackPainting(slug: string) {
  const available = paintings.filter(p => !usedIds.has(p.imageId));
  if (available.length === 0) return paintings[0]; // ultimate fallback
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  const pick = available[Math.abs(h) % available.length];
  usedIds.add(pick.imageId); // reserve it
  return pick;
}

function getPainting(slug: string) {
  return paintings[slugHash(slug) % paintings.length];
}

// Generate unique block overlay pattern from slug
// Returns array of {x, y, w, h} in grid units (8 cols x 4 rows)
function generateBlockPattern(slug: string): Array<{x: number, y: number, w: number, h: number}> {
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  h = Math.abs(h);

  const blocks: Array<{x: number, y: number, w: number, h: number}> = [];
  const cols = 8;
  const rows = 3;

  // Sparse: only pick 2-4 blocks from corners/edges
  // Top-left corner
  if (h & 1) blocks.push({ x: 0, y: 0, w: 1, h: 1 });
  // Top-right corner
  if (h & 4) blocks.push({ x: cols - 1, y: 0, w: 1, h: 1 });
  // One top-edge block
  if (h & 16) blocks.push({ x: 1 + ((h >> 5) % (cols - 2)), y: 0, w: 1, h: 1 });
  // One side block
  if (h & 64) blocks.push({ x: (h & 128) ? 0 : cols - 1, y: 1 + ((h >> 8) % (rows - 1)), w: 1, h: 1 });

  return blocks;
}

function blockPatternSvg(slug: string, featured: boolean): string {
  const blocks = generateBlockPattern(slug);
  const cols = 8;
  const rows = 3;
  // SVG viewBox: percentage-based
  const rects = blocks.map(b => {
    const x = (b.x / cols * 100).toFixed(2);
    const y = (b.y / rows * 100).toFixed(2);
    const w = (b.w / cols * 100).toFixed(2);
    const h = (b.h / rows * 100).toFixed(2);
    return `<rect x="${x}%" y="${y}%" width="${w}%" height="${h}%" fill="white"/>`;
  }).join('');
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="none" style="position:absolute;inset:0;width:100%;height:100%;pointer-events:none;">${rects}</svg>`;
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 2.5rem 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card.featured {
      grid-column: span 2;
    }

    .post-card.featured .post-thumb {
      aspect-ratio: 16 / 7;
    }

    .post-card.featured .post-card-title {
      font-size: 1.25rem;
    }

    @media (max-width: 480px) {
      .post-card.featured {
        grid-column: span 1;
      }
      .post-card.featured .post-thumb {
        aspect-ratio: 16 / 6;
      }
      .post-card.featured .post-card-title {
        font-size: 0.95rem;
      }
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      opacity: 0.85;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 16 / 6;
      border-radius: 4px;
      overflow: hidden;
      background: #f0ede8;
      transition: opacity 0.2s;
      position: relative;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {zhPosts.map((post, i) => {
      const enPost = enMap.get(post.id);
      const fb = post.data.painting_id ? null : getFallbackPainting(post.id);
      const pId = post.data.painting_id || fb!.imageId;
      const pTitle = post.data.painting_title || fb?.title || '';
      const pArtist = post.data.painting_artist || fb?.artist || '';
      const isFeatured = i === 0;
      const imgUrl = `${AIC_IIIF}/${pId}/full/${isFeatured ? '800' : '400'},/0/default.jpg`;
      const zhExcerpt = getExcerpt(post.body ?? '');
      const enExcerpt = enPost ? getExcerpt(enPost.body ?? '') : zhExcerpt;
      return (
        <li class={`post-card${isFeatured ? ' featured' : ''}`}>
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
            <div class="post-thumb">
              <img src={imgUrl} alt={`${pTitle} — ${pArtist}`} />
              <Fragment set:html={blockPatternSvg(post.id, isFeatured)} />
            </div>
            <div class="post-card-body">
              <div class="post-card-date">{post.data.date}</div>
              <h2 class="post-card-title"
                data-zh={post.data.title}
                data-en={post.data.title_en || post.data.title}>
                {post.data.title}
              </h2>
              <p class="post-card-excerpt"
                data-zh-excerpt={zhExcerpt}
                data-en-excerpt={enExcerpt}>
                {zhExcerpt}
              </p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>
