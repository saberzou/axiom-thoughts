---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const allPosts = await getCollection('thoughts');

// Only show zh posts in the index
const zhPosts = allPosts
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Build a map of en posts by base slug (strip ".en" suffix)
const enMap = new Map(
  allPosts
    .filter(p => p.data.lang === 'en')
    .map(p => [p.id.replace(/en$/, ''), p])
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 100) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 100) {
        clean = clean.slice(0, 100) + '…';
      }
      return clean;
    }
  }
  return '';
}

// Impressionist landscape paintings from Art Institute of Chicago (open access)
const AIC_IIIF = 'https://www.artic.edu/iiif/2';
const paintings = [
  // Monet
  { imageId: '3c27b499-af56-f0d5-93b5-a7f2f1ad5813', title: 'Water Lilies', artist: 'Claude Monet' },
  { imageId: 'a38e2828-ec6f-ece1-a30f-70243449197b', title: 'Stacks of Wheat (End of Summer)', artist: 'Claude Monet' },
  { imageId: '95be2572-b53d-8e7b-abc9-10eb48d4fa5d', title: 'The Beach at Sainte-Adresse', artist: 'Claude Monet' },
  { imageId: 'b0effb1c-ff23-bbaa-f809-9fd94e31c1a0', title: 'Cliff Walk at Pourville', artist: 'Claude Monet' },
  { imageId: '4d1b3ad0-14db-0d21-ad9f-17abb8bdfbb5', title: 'Bordighera', artist: 'Claude Monet' },
  { imageId: '4c364c64-2108-4e19-5fc5-1ab26ba924a7', title: 'Stacks of Wheat (End of Day, Autumn)', artist: 'Claude Monet' },
  // Sisley
  { imageId: '0f076222-52b2-9bb4-4409-72fdf485d895', title: 'A Turn in the Road', artist: 'Alfred Sisley' },
  { imageId: 'c4425cb6-d8b5-6390-603d-7f802406d05d', title: 'The Seine at Port-Marly', artist: 'Alfred Sisley' },
  { imageId: 'bcc9c3a7-f5b0-41af-210a-bd17797d77d9', title: 'The Loire', artist: 'Alfred Sisley' },
  { imageId: 'ed7aa098-e5c9-04dd-b09c-3416d1c56854', title: 'Watering Place at Marly', artist: 'Alfred Sisley' },
  // Pissarro
  { imageId: '053f9be8-3617-c4ef-36cd-1deb5e13b288', title: 'Rabbit Warren at Pontoise, Snow', artist: 'Camille Pissarro' },
  { imageId: '3d950ecc-73f4-c28a-f216-0940b23fa5e8', title: 'The Banks of the Marne in Winter', artist: 'Camille Pissarro' },
  { imageId: 'b84a9755-ca8d-8bd5-5a59-e910b20e3ba5', title: 'Haymaking at Éragny', artist: 'Camille Pissarro' },
  { imageId: '4eb368b5-3b66-ae2c-bd4a-2643015e05fc', title: 'The Crystal Palace', artist: 'Camille Pissarro' },
  // Cézanne
  { imageId: 'd4ca6321-8656-3d3f-a362-2ee297b2b813', title: 'The Bay of Marseille', artist: 'Paul Cézanne' },
  { imageId: '90bc0cec-0d4e-9af5-3912-52a082a428e5', title: 'Auvers, Panoramic View', artist: 'Paul Cézanne' },
  // Van Gogh
  { imageId: 'd4bc1723-7cbc-d36d-a9cb-f84553f2a6f6', title: 'The Poet\'s Garden', artist: 'Vincent van Gogh' },
  { imageId: '5512cee9-6d00-d01b-b0be-ac7843cc8f76', title: 'Fishing in Spring, Pont de Clichy', artist: 'Vincent van Gogh' },
  { imageId: '6cb22407-be79-bf0a-1a63-fdf2b99e035b', title: 'Terrace at the Moulin de la Galette', artist: 'Vincent van Gogh' },
  { imageId: '25c31d8d-21a4-9ea1-1d73-6a2eca4dda7e', title: 'The Bedroom', artist: 'Vincent van Gogh' },
];

function slugHash(slug: string): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) {
    h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  }
  return Math.abs(h);
}

function getPainting(slug: string) {
  return paintings[slugHash(slug) % paintings.length];
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      opacity: 0.85;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 16 / 6;
      border-radius: 12px;
      overflow: hidden;
      background: #f0ede8;
      transition: opacity 0.2s;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {zhPosts.map(post => {
      const enPost = enMap.get(post.id);
      const painting = getPainting(post.id);
      const imgUrl = `${AIC_IIIF}/${painting.imageId}/full/400,/0/default.jpg`;
      const zhExcerpt = getExcerpt(post.body ?? '');
      const enExcerpt = enPost ? getExcerpt(enPost.body ?? '') : zhExcerpt;
      return (
        <li class="post-card">
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
            <div class="post-thumb">
              <img src={imgUrl} alt={`${painting.title} — ${painting.artist}`} />
            </div>
            <div class="post-card-body">
              <div class="post-card-date">{post.data.date}</div>
              <h2 class="post-card-title"
                data-zh={post.data.title}
                data-en={post.data.title_en || post.data.title}>
                {post.data.title}
              </h2>
              <p class="post-card-excerpt"
                data-zh-excerpt={zhExcerpt}
                data-en-excerpt={enExcerpt}>
                {zhExcerpt}
              </p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>
