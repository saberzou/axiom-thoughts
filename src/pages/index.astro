  { imageId: '90bc0cec-0d4e-9af5-3912-52a082a428e5', title: 'Auvers, Panoramic View', artist: 'Paul Cézanne' },
  { imageId: 'd4bc1723-7cbc-d36d-a9cb-f84553f2a6f6', title: "The Poet's Garden", artist: 'Vincent van Gogh' },
  { imageId: '5512cee9-6d00-d01b-b0be-ac7843cc8f76', title: 'Fishing in Spring, Pont de Clichy', artist: 'Vincent van Gogh' },
  { imageId: '6cb22407-be79-bf0a-1a63-fdf2b99e035b', title: 'Terrace at the Moulin de la Galette', artist: 'Vincent van Gogh' },
  { imageId: 'caf4fa39-e2e8-344a-542c-2d9a03ec9d4b', title: 'Seascape', artist: 'Pierre-Auguste Renoir' },
  { imageId: '26e1c560-acca-3148-46dc-c144ac22bd3e', title: 'Near the Lake', artist: 'Pierre-Auguste Renoir' },
  { imageId: '5dfcbae3-6682-d1e6-0d1c-9eb8b5fd4a5e', title: 'Grove of Trees', artist: 'Pierre-Auguste Renoir' },
];

// Collect painting_ids already claimed by frontmatter
const usedIds = new Set(
  allPosts.filter(p => p.data.painting_id).map(p => p.data.painting_id)
);

// Auto-assign unique paintings to posts without painting_id
function getFallbackPainting(slug: string) {
  const available = paintings.filter(p => !usedIds.has(p.imageId));
  if (available.length === 0) return paintings[0]; // ultimate fallback
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  const pick = available[Math.abs(h) % available.length];
  usedIds.add(pick.imageId); // reserve it
  return pick;
}

function getPainting(slug: string) {
  return paintings[slugHash(slug) % paintings.length];
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      opacity: 0.85;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 16 / 6;
      border-radius: 4px;
      overflow: hidden;
      background: #f0ede8;
      transition: opacity 0.2s;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
      font-family: 'Google Sans', system-ui, sans-serif;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {zhPosts.map(post => {
      const enPost = enMap.get(post.id);
      const fb = post.data.painting_id ? null : getFallbackPainting(post.id);
      const pId = post.data.painting_id || fb!.imageId;
      const pTitle = post.data.painting_title || fb?.title || '';
      const pArtist = post.data.painting_artist || fb?.artist || '';
      const imgUrl = `${AIC_IIIF}/${pId}/full/400,/0/default.jpg`;
      const zhExcerpt = getExcerpt(post.body ?? '');
      const enExcerpt = enPost ? getExcerpt(enPost.body ?? '') : zhExcerpt;
      return (
        <li class="post-card">
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
            <div class="post-thumb">
              <img src={imgUrl} alt={`${pTitle} — ${pArtist}`} />
            </div>
            <div class="post-card-body">
              <div class="post-card-date">{post.data.date}</div>
              <h2 class="post-card-title"
                data-zh={post.data.title}
                data-en={post.data.title_en || post.data.title}>
                {post.data.title}
              </h2>
              <p class="post-card-excerpt"
                data-zh-excerpt={zhExcerpt}
                data-en-excerpt={enExcerpt}>
                {zhExcerpt}
              </p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>
