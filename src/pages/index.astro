---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 100) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 100) {
        clean = clean.slice(0, 100) + '…';
      }
      return clean;
    }
  }
  return '';
}

// Impressionist paintings from Art Institute of Chicago (open access)
const AIC_IIIF = 'https://www.artic.edu/iiif/2';
const paintings = [
  { imageId: 'a6b1cdb3-accf-e571-9040-a3e7b5d2d860', title: 'Water Lilies', artist: 'Claude Monet' },
  { imageId: 'fe57e1fd-b2c3-e89e-cd4d-14ba50b25f31', title: 'Two Sisters (On the Terrace)', artist: 'Pierre-Auguste Renoir' },
  { imageId: '1adf2696-8489-499b-cad2-821d7fde4b33', title: 'A Sunday on La Grande Jatte', artist: 'Georges Seurat' },
  { imageId: '9b71c4b5-8a9a-8de7-78a0-8d4eb0cee2ed', title: 'Paris Street; Rainy Day', artist: 'Gustave Caillebotte' },
  { imageId: 'c413e475-8db7-8e0d-5b19-a0d24a6d6e63', title: 'The Bay of Marseille', artist: 'Paul Cézanne' },
  { imageId: '2d484387-2509-5e8e-2c43-22f9981972eb', title: 'Self-Portrait', artist: 'Vincent van Gogh' },
  { imageId: '19ead5a4-f7a8-8474-0c4b-0285e729f1e7', title: 'The Beach at Sainte-Adresse', artist: 'Claude Monet' },
  { imageId: '73d5b2c3-ba87-eab7-98a8-b52a42aabf4d', title: 'Arrival of the Normandy Train', artist: 'Claude Monet' },
  { imageId: '25c31d8d-21a4-9ea1-1d73-6a2eca4dda7e', title: 'Henri Degas and His Niece', artist: 'Edgar Degas' },
  { imageId: '5c5d98e9-2ef3-82e8-6ecd-7ab7b5e19bb5', title: 'Acrobats at the Cirque Fernando', artist: 'Pierre-Auguste Renoir' },
];

function slugHash(slug: string): number {
  let h = 0;
  for (let i = 0; i < slug.length; i++) {
    h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  }
  return Math.abs(h);
}

function getPainting(slug: string) {
  return paintings[slugHash(slug) % paintings.length];
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      opacity: 0.85;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 4 / 3;
      border-radius: 12px;
      overflow: hidden;
      background: #f0ede8;
      transition: opacity 0.2s;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {posts.map(post => {
      const painting = getPainting(post.id);
      const imgUrl = `${AIC_IIIF}/${painting.imageId}/full/400,/0/default.jpg`;
      return (
        <li class="post-card">
          <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
            <div class="post-thumb">
              <img src={imgUrl} alt={`${painting.title} — ${painting.artist}`} loading="lazy" />
            </div>
            <div class="post-card-body">
              <div class="post-card-date">{post.data.date}</div>
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-excerpt">{getExcerpt(post.body)}</p>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</Base>
