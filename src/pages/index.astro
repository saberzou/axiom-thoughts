---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  // Get first non-empty, non-heading, non-blockquote line of real content
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      // Strip markdown formatting
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      // Truncate at first sentence or 120 chars
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 120) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 120) {
        clean = clean.slice(0, 120) + '…';
      }
      return clean;
    }
  }
  return '';
}
---
<Base title="Axiom Thoughts">
  <style>
    .post-list {
      list-style: none;
    }

    .post-item {
      padding: 1.5rem 0;
      border-bottom: 1px solid #eee;
    }

    .post-item:first-child {
      border-top: 1px solid #eee;
    }

    .post-meta {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 0.8rem;
      color: #888;
      letter-spacing: 0.03em;
      margin-bottom: 0.3rem;
    }

    .post-title {
      font-size: 1.1rem;
      font-weight: normal;
      margin-bottom: 0.35rem;
    }

    .post-title a {
      color: #111;
      text-decoration: none;
    }

    .post-title a:hover {
      text-decoration: underline;
    }

    .post-excerpt {
      font-size: 0.9rem;
      color: #555;
      line-height: 1.6;
    }
  </style>

  <ul class="post-list">
    {posts.map(post => (
      <li class="post-item">
        <div class="post-meta">{post.data.date}</div>
        <h2 class="post-title">
          <a href={`${import.meta.env.BASE_URL}${post.id}`}>{post.data.title}</a>
        </h2>
        <p class="post-excerpt">{getExcerpt(post.body)}</p>
      </li>
    ))}
  </ul>
</Base>
