---
import { getCollection } from 'astro:content';
import { paintings, LOCAL_PAINTINGS } from '../data/paintings';
import InfiniteCanvas from '../components/InfiniteCanvas';

const allPosts = await getCollection('thoughts');

// zh posts sorted newest first
const zhPosts = allPosts
  .filter(p => p.data.lang === 'zh')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// en posts keyed by base id
// Note: Astro glob loader strips dots from filenames, so
// "2026-03-07-kafka.en.md" → id "2026-03-07-kafkaen" (no dot)
const enMap = new Map(
  allPosts
    .filter(p => p.data.lang === 'en')
    .map(p => [p.id.replace(/\.?en$/, ''), p])
);

// Fallback painting assignment (same logic as before, deterministic)
const usedIds = new Set(allPosts.filter(p => p.data.painting_id).map(p => p.data.painting_id));

function getFallbackPainting(slug: string) {
  const available = paintings.filter(p => !usedIds.has(p.imageId));
  const pool = available.length > 0 ? available : paintings;
  let h = 0;
  for (let i = 0; i < slug.length; i++) h = (h * 31 + slug.charCodeAt(i)) & 0xffffffff;
  const pick = pool[Math.abs(h) % pool.length];
  usedIds.add(pick.imageId);
  return pick;
}

function getExcerpt(body: string): string {
  for (const line of body.split('\n')) {
    const t = line.trim();
    if (t && !t.startsWith('#') && !t.startsWith('>') && !t.startsWith('*') && !t.startsWith('-') && !t.startsWith('_')) {
      let clean = t.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const end = clean.search(/[。！？.!?]/);
      if (end > 0 && end < 100) clean = clean.slice(0, end + 1);
      else if (clean.length > 100) clean = clean.slice(0, 100) + '…';
      return clean;
    }
  }
  return '';
}

// Build post data array for the React canvas
const postsData = zhPosts.map(post => {
  const enPost = enMap.get(post.id);
  const fb = post.data.painting_id ? null : getFallbackPainting(post.id);
  const painting_id = post.data.painting_id || fb!.imageId;
  const painting_title = post.data.painting_title || fb?.title || '';
  const painting_artist = post.data.painting_artist || fb?.artist || '';

  return {
    id: post.id,
    title: post.data.title,
    title_en: post.data.title_en || post.data.title,
    date: post.data.date,
    tags: post.data.tags || [],
    series: post.data.series || undefined,
    painting_id,
    painting_title,
    painting_artist,
    body: post.body || '',
    body_en: enPost?.body || '',
    excerpt: getExcerpt(post.body || ''),
    excerpt_en: enPost ? getExcerpt(enPost.body || '') : getExcerpt(post.body || ''),
  };
});

const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Axiom Thoughts</title>
  <meta name="description" content="一只狐狸读书时留下的脚印" />
  <link rel="icon" href={`${basePath}/favicon.ico`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@300;400&family=Noto+Sans+SC:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html, body {
      margin: 0; padding: 0;
      background: #0f0e0c;
      font-family: 'Noto Sans SC', sans-serif;
    }
  </style>
</head>
<body>
  <InfiniteCanvas posts={postsData} basePath={basePath} client:only="react" />
</body>
</html>
