---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const posts = (await getCollection('thoughts')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getExcerpt(body: string): string {
  const lines = body.split('\n');
  for (const line of lines) {
    const trimmed = line.trim();
    if (
      trimmed &&
      !trimmed.startsWith('#') &&
      !trimmed.startsWith('>') &&
      !trimmed.startsWith('*') &&
      !trimmed.startsWith('-') &&
      !trimmed.startsWith('_')
    ) {
      let clean = trimmed.replace(/\*\*(.+?)\*\*/g, '$1').replace(/\*(.+?)\*/g, '$1');
      const sentenceEnd = clean.search(/[。！？.!?]/);
      if (sentenceEnd > 0 && sentenceEnd < 100) {
        clean = clean.slice(0, sentenceEnd + 1);
      } else if (clean.length > 100) {
        clean = clean.slice(0, 100) + '…';
      }
      return clean;
    }
  }
  return '';
}

const defaultIcon = 'Content-Files-Books-2--Streamline-Pixel';
---
<Base title="Axiom Thoughts">
  <style>
    .post-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .post-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
    }

    @media (max-width: 480px) {
      .post-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .post-card {
      display: flex;
      flex-direction: column;
    }

    .post-card a {
      text-decoration: none;
      color: inherit;
    }

    .post-card a:hover .post-thumb {
      background-color: #e6b800;
    }

    .post-card a:hover .post-card-title {
      color: #555;
    }

    .post-thumb {
      aspect-ratio: 16 / 6;
      background: #F5C800;
      border-radius: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background-color 0.2s;
    }

    .post-thumb img {
      width: 48px;
      height: 48px;
      image-rendering: pixelated;
      filter: none;
    }

    .post-card-body {
      padding: 0.75rem 0 0;
    }

    .post-card-date {
      font-size: 0.7rem;
      color: #999;
      letter-spacing: 0.04em;
      margin-bottom: 0.25rem;
    }

    .post-card-title {
      font-size: 0.95rem;
      font-weight: 300;
      line-height: 1.4;
      margin-bottom: 0.35rem;
      color: #111;
    }

    .post-card-excerpt {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.5;
    }
  </style>

  <ul class="post-grid">
    {posts.map(post => (
      <li class="post-card">
        <a href={`${import.meta.env.BASE_URL}/${post.id}`}>
          <div class="post-thumb">
            <img src={`${import.meta.env.BASE_URL}/icons/${post.data.icon || defaultIcon}.svg`} alt="" />
          </div>
          <div class="post-card-body">
            <div class="post-card-date">{post.data.date}</div>
            <h2 class="post-card-title">{post.data.title}</h2>
            <p class="post-card-excerpt">{getExcerpt(post.body)}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>
